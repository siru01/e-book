{
  "version": 2,
  "builds": [
    {
      "src": "library_backend/config/wsgi.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.12" }
    },
    {
      "src": "library_frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "library_backend/config/wsgi.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "library_backend/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "library_frontend/$1"
    }
  ]
}
